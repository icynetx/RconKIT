[0.168468, "o", "\r\n   / __ \\___  _________  ____ / //_(_) /_\r\n  / /_/ / _ \\/ ___/ __ \\/ __ \\/ ,< / / __/\r\n / _, _/  __/ /__/ /_/ / / / / /| / / /_\r\n/_/ |_|\\___/\\___/\\____/_/ /_//_/ |_/_/\\__/\u001b[0m\r\n\u001b[35m╭  ReconKit Home  ───────────────────────────────────────╮\u001b[0m\r\n\u001b[35m│ \u001b[0m\u001b[1m\u001b[36m⚡ authorized recon dashboard\u001b[0m                          \u001b[35m │\u001b[0m\r\n\u001b[35m│ \u001b[0m\u001b[1m\u001b[35m MODE \u001b[0m \u001b[37mfriendly launcher\u001b[0m                              \u001b[35m │\u001b[0m\r\n\u001b[35m│ \u001b[0m\u001b[1m\u001b[32m RUN \u001b[0m \u001b[37mreconkit <target>\u001b[0m                               \u001b[35m │\u001b[0m\r\n\u001b[35m│ \u001b[0m\u001b[1m\u001b[33m SETUP \u001b[0m \u001b[37mreconkit --install-deps --with-optional\u001b[0m       \u001b[35m │\u001b[0m\r\n\u001b[35m╰────────────────────────────────────────────────────────╯\u001b[0m\r\n\u001b[2m───\u001b[0m\u001b[1m\u001b[36m Quick Actions \u001b[0m\u001b[2m───────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\u001b[1m\u001b[37mAction               │ Command                                                     \u001b[0m\r\n\u001b[2m─────────────────────┼─────────────────────────────────────────────────────────────\u001b[0m\r\nStart scan           │ reconkit example.com                                        \r\nFull mission         │ reconkit example.com --mission --raw-dir artifacts -o       \r\n                     │ scan.json --html report.html                                \r\nInstall command only │ python3 recon.py --self-install --user                      \r\nInstall tools        │ reconkit --install-deps --with-optional                     \r\nCheck setup          │ reconkit --check-deps                                       \r\nAI test              │ reconkit --test-ai                                          \r\n\u001b[2m───\u001b[0m\u001b[1m\u001b[36m Operator Notes \u001b[0m\u001b[2m──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\u001b[1m\u001b[37mSignal         │ Meaning                                                     \u001b[0m\r\n\u001b[2m───────────────┼─────────────────────────────────────────────────────────────\u001b[0m\r\nNo target?     │ This screen opens instead of an error.                      \r\nSafe by design │ No brute-force, exploit payloads, persistence, or           \r\n               │ destructive actions.                                        \r\nReports        │ Use -o scan.json --markdown report.md --html report.html    \r\n"]
